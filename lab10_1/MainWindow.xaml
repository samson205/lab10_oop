<Window x:Class="lab10_1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:lab10_1"
        mc:Ignorable="d"
        Title="Магазин бытовой техники" Height="600" Width="900">

    <Window.Resources>
        <SolidColorBrush x:Key="MainColor" Color="#2C3E50"/>
        <SolidColorBrush x:Key="AccentColor" Color="#3498DB"/>
        <SolidColorBrush x:Key="LightColor" Color="#ECF0F1"/>

        <Style x:Key="HeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="5"/>
        </Style>

        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="5"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                        Background="{TemplateBinding Background}"
                        CornerRadius="15"
                        Padding="{TemplateBinding Padding}">

                            <ContentPresenter
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                                Property="Opacity"
                                Value="0.85"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border"
                                Property="Opacity"
                                Value="0.7"/>
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Background="{StaticResource LightColor}">

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <Border Background="{StaticResource MainColor}" Grid.Row="0">
            <TextBlock Text="Магазин бытовой техники"
                       Style="{StaticResource HeaderStyle}" VerticalAlignment="Center"/>
        </Border>

        <Grid Grid.Row="1" Margin="10">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">

                <GroupBox Header="Категории товаров" Margin="5">
                    <ListBox x:Name="boxCategory" SelectionChanged="boxCategory_SelectionChanged"/>
                </GroupBox>

                <GroupBox Header="Условия кредита" Margin="5">
                    <StackPanel>
                        <TextBlock Text="0% на 6 месяцев"/>
                        <TextBlock Text="10% на 12 месяцев"/>
                        <TextBlock Text="15% на 24 месяца"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Условия доставки" Margin="5">
                    <StackPanel>
                        <TextBlock Text="Бесплатно от 500€"/>
                        <TextBlock Text="20€ по городу"/>
                        <TextBlock Text="40€ по области"/>
                    </StackPanel>
                </GroupBox>

            </StackPanel>

            <GroupBox Header="Прайс-лист" Grid.Column="1" Margin="5">
                <DataGrid x:Name="PriceGrid" AutoGenerateColumns="False">

                    <DataGrid.Columns>

                        <DataGridTextColumn 
                            Header="Товар"
                            Binding="{Binding Name}"
                            Width="*"/>

                        <DataGridTextColumn 
                            Header="Категория"
                            Binding="{Binding Category}"
                            Width="150"/>

                        <DataGridTextColumn 
                            Header="Цена (€)"
                            Binding="{Binding Price}"
                            Width="100"/>

                        <DataGridTextColumn 
                            Header="В наличии"
                            Binding="{Binding Count}"
                            Width="100"/>

                    </DataGrid.Columns>

                </DataGrid>
            </GroupBox>

        </Grid>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Grid.Row="2">

            <Button Content="Добавить"
                    Click="AddButton_Click"
                    Style="{StaticResource ButtonStyle}"
                    Width="120"/>

            <Button Content="Удалить"
                    Click="DeleteButton_Click"
                    Style="{StaticResource ButtonStyle}"
                    Width="120"/>

            <Button Content="Сформировать прайс"
                    Click="GenerateButton_Click"
                    Style="{StaticResource ButtonStyle}"
                    Width="170"/>

        </StackPanel>

    </Grid>

</Window>